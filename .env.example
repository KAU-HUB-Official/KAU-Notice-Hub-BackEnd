NOTICE_JSON_PATH=./data/kau_official_posts.json
NOTICE_DB_PATH=./data/kau_notice_hub.db
# 쉼표로 구분한 허용 frontend origin. 아래는 로컬 개발 기본값이다.
# 운영(Lightsail .env)에는 배포된 프론트 origin을 반드시 넣는다. 예:
#   BACKEND_CORS_ORIGINS=https://kau-notice-hub.vercel.app,http://localhost:3000
# 프론트와 API가 같은 도메인(같은 origin)이면 CORS는 발동하지 않는다.
BACKEND_CORS_ORIGINS=http://localhost:3000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LOG_LEVEL=INFO
# Per-IP 레이트리밋(slowapi, 인메모리). 형식: "<횟수>/<기간>" (minute, hour 등).
# api는 Caddy 뒤에 있고 Caddy가 X-Real-IP를 set 한다. 끄려면 RATE_LIMIT_ENABLED=false.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_CHAT=15/minute
RATE_LIMIT_NOTICES=120/minute
# BFF(Next.js/Vercel) 프록시가 실제 브라우저 IP를 전달할 때 쓰는 공유 시크릿.
# 프론트의 NOTICE_API_INTERNAL_TOKEN과 같은 값으로 맞춘다(랜덤 문자열). 비우면
# 전달 IP를 무시하고 직접 peer IP만 쓴다 → BFF 뒤에선 레이트리밋이 전체 공용이 됨.
INTERNAL_PROXY_TOKEN=
CONTENT_ENRICHMENT_ENABLED=false
CONTENT_ENRICHMENT_PROVIDER=openai
CONTENT_ENRICHMENT_MODEL=gpt-4.1-mini
CONTENT_ENRICHMENT_FALLBACK_MODEL=gpt-5.5
CONTENT_ENRICHMENT_IMAGE_DETAIL=high
CONTENT_ENRICHMENT_MIN_TEXT_LENGTH=30
CONTENT_ENRICHMENT_MAX_ASSETS_PER_NOTICE=3
CONTENT_ENRICHMENT_MAX_FILE_BYTES=10485760
CONTENT_ENRICHMENT_MAX_CALLS_PER_RUN=50
# 비우면 공개 IP로 해석되는 모든 호스트를 허용한다(localhost·사설 IP는 계속 차단).
# 특정 도메인으로 제한하려면 콤마로 구분해 지정한다.
CONTENT_ENRICHMENT_ALLOWED_DOMAINS=
CRAWLER_SCHEDULER_ENABLED=false
CRAWLER_INTERVAL_SECONDS=10800
CRAWLER_RUN_ON_STARTUP=true
CRAWLER_MAX_PAGES=0
CRAWLER_MIN_RECORDS=1
CRAWLER_MIN_RETAIN_RATIO=0.5
RAG_ENABLED=false
RAG_MAX_REFERENCES=6
RAG_CANDIDATE_POOL=15
RAG_QUERY_EXTRACTION_ENABLED=true
# 챗봇 Q/A 세션 로깅(평가셋·개선용). true이고 요청에 sessionId가 있을 때만 저장한다.
# 운영 notice DB와 분리된 별도 append 전용 SQLite 파일에 쌓인다.
CHAT_LOGGING_ENABLED=false
CHAT_LOG_DB_PATH=./data/chat_sessions.db
