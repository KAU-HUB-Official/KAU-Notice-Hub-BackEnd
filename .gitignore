.env
.env.*
!.env.example

# Runtime logs and local process files
*.log
nohup.out
.uvicorn.log
.uvicorn.pid

# Local data snapshots
data/*.json
data/*.tmp
data/*.tmp.*
!data/.gitkeep

# OS / editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

