*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# Test and coverage outputs
.coverage
.coverage.*
coverage.xml
htmlcov/

# Packaging and build outputs
*.egg-info/
.eggs/
build/
dist/
wheelhouse/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/
