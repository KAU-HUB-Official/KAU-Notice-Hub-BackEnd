*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
coverage.xml
htmlcov/

# Packaging / build outputs
*.egg-info/
.eggs/
build/
dist/
wheelhouse/

